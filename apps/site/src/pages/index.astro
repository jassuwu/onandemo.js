---
import Window from "../components/Window.astro";
import Layout from "../layouts/Layout.astro";

const scriptSnippet = `<script src="https://unpkg.com/onandemo/dist/onandemo.js"><\/script>`;
const npmSnippet = `bun add onandemo`;
const importSnippet = `import { onandemo } from "onandemo";

const destroy = onandemo(); // the cat
onandemo({ sheet: "/dino.png", frameMap }); // anything`;

const knobs = [
  ["sheet + frameMap", "—", "your art and its map"],
  ["preset", '"neko"', "bundled companion by name"],
  ["speed", "10", "px per tick"],
  ["restRadius", "48", "rest distance"],
  ["scale", "1", "display multiplier"],
  ["zIndex", "2147483647", "stacking"],
  ["persist", "true", "remembers its spot"],
];

const manners = [
  "bails out under prefers-reduced-motion — no element, no listeners.",
  "never intercepts input; hidden from assistive tech.",
  "the loop dies when the element leaves the DOM.",
  "remembers where it was (persist: false opts out).",
  "ten frames per second, always. the shuffle is the charm.",
];

const ladder = [
  [
    "01",
    "try",
    "summon the bundled three — they're loose on this desktop already.",
  ],
  [
    "02",
    "make",
    "no art skills? the recipe prompts your image model. have pixels? the playground slices anything.",
  ],
  [
    "03",
    "mint",
    "the playground turns your creature into a link. send it; whoever opens it gets chased. nothing uploads — the whole companion lives in the url.",
  ],
  [
    "04",
    "immortalize",
    "pr your companion into the package. it ships on npm, works as data-preset everywhere, and notice.md credits you.",
  ],
];
---

<Layout>
  <main class="mx-auto max-w-6xl space-y-10 px-4 py-10 sm:px-6">
    <!-- about -->
    <Window title="about onandemo.js" class="max-w-3xl">
      <p class="label">o-nandemo (何でも) — "anything"</p>
      <h1 class="mt-2 text-5xl font-bold tracking-tight sm:text-7xl">
        onandemo.js
      </h1>
      <p class="mt-3 text-xl">oneko.js, but anything chases your cursor.</p>
      <p class="label mt-8">it's already chasing you. who's next:</p>
      <div class="mt-3 flex flex-wrap gap-3" id="switcher">
        <button class="btn-amber" data-preset="neko" aria-pressed="true"
          >neko</button
        >
        <button class="btn-amber" data-preset="soldier" aria-pressed="false"
          >soldier</button
        >
        <button class="btn-amber" data-preset="slime" aria-pressed="false"
          >slime</button
        >
      </div>
      <p class="mt-5 text-sm">
        or <a href="/playground" class="prose-link">mint one of your own</a>.
      </p>
    </Window>

    <!-- install -->
    <div class="grid items-start gap-10 lg:grid-cols-2">
      <Window title="install">
        <div class="flex items-baseline justify-between gap-3">
          <span class="label">drop-in</span>
          <button class="btn" data-copy={scriptSnippet}>copy</button>
        </div>
        <pre
          class="border-ink mt-3 overflow-x-auto border-2 p-3 font-mono text-sm"><code>{scriptSnippet}</code></pre>
        <p class="mt-3 text-sm">
          swap with <code class="font-mono">data-preset="soldier"</code> or
          <code class="font-mono">"slime"</code> — the files ship inside the package.
        </p>
        <div class="mt-5 flex items-baseline justify-between gap-3">
          <span class="label">npm</span>
          <button class="btn" data-copy={npmSnippet}>copy</button>
        </div>
        <pre
          class="border-ink mt-3 overflow-x-auto border-2 p-3 font-mono text-sm"><code>{npmSnippet}</code></pre>
        <pre
          class="mt-3 overflow-x-auto p-1 font-mono text-sm"><code>{importSnippet}</code></pre>
      </Window>

      <!-- make your own: the ladder -->
      <Window title="make your own">
        <ol class="space-y-4">
          {
            ladder.map(([num, name, what]) => (
              <li class="flex gap-4">
                <span class="label text-amber-deep mt-1 shrink-0">{num}</span>
                <span>
                  <strong class="font-bold">{name}</strong> — {what}
                </span>
              </li>
            ))
          }
        </ol>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/playground" class="btn-amber inline-block">playground</a>
          <a href="/recipe" class="btn inline-block">recipe</a>
          <a
            href="https://github.com/jassuwu/onandemo.js/blob/main/CONTRIBUTING.md"
            class="btn inline-block">pr yours</a
          >
        </div>
      </Window>
    </div>

    <!-- anatomy -->
    <Window title="anatomy of a companion — neko.gif" class="max-w-fit">
      <p class="max-w-2xl text-sm">
        a sheet is a grid of cells; a frame map names them. this is the actual
        cat — all 32 cells, mapped. hover around.
      </p>
      <div class="mt-5 overflow-x-auto pb-1">
        <div
          id="anatomy"
          class="border-ink relative w-[768px] border-2 select-none"
          style="image-rendering: pixelated;"
        >
          <img
            src="/presets/neko.gif"
            alt="the classic cat sprite sheet, 8 by 4 cells"
            width="768"
            height="384"
            class="block"
            style="image-rendering: pixelated;"
            draggable="false"
          />
          <div class="absolute inset-0 grid grid-cols-8 grid-rows-4"></div>
        </div>
      </div>
      <p class="label mt-3 h-5">
        cell: <span id="anatomy-readout" class="text-amber-deep"
          >hover a cell</span
        >
      </p>
    </Window>

    <!-- rules -->
    <div class="grid items-start gap-10 lg:grid-cols-2">
      <Window title="the knobs">
        <table class="w-full font-mono text-sm">
          <tbody>
            {
              knobs.map(([knob, def, what]) => (
                <tr class="border-ink/30 border-b">
                  <td class="py-2 pr-3 font-bold">{knob}</td>
                  <td class="py-2 pr-3">{def}</td>
                  <td class="py-2">{what}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </Window>
      <Window title="the manners">
        <ul class="space-y-3">
          {
            manners.map((m) => (
              <li class="flex gap-3">
                <span class="label mt-1">■</span>
                <span>{m}</span>
              </li>
            ))
          }
        </ul>
        <p class="mt-5 text-sm">
          inherited from oneko, engine behavior rather than options. not
          configurable on purpose.
        </p>
      </Window>
    </div>
  </main>

  <script>
    import type { PresetName } from "../lib/companion.ts";

    // switcher
    const switcher = document.getElementById("switcher");
    switcher?.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(
        "[data-preset]",
      );
      if (!btn) return;
      void window.companion.summon(btn.dataset["preset"] as PresetName);
      for (const b of switcher.querySelectorAll("[data-preset]")) {
        b.setAttribute("aria-pressed", String(b === btn));
      }
    });

    // anatomy: the cat's cells, labeled (mirrors the bundled neko frame map)
    const STATES: Record<string, string> = {};
    const label = (name: string, cells: [number, number][]) => {
      cells.forEach(([c, r], i) => {
        STATES[`${c},${r}`] = `${name} · frame ${i + 1}/${cells.length}`;
      });
    };
    label("idle", [[3, 3]]);
    label("alert", [[7, 3]]);
    label("N", [
      [1, 2],
      [1, 3],
    ]);
    label("NE", [
      [0, 2],
      [0, 3],
    ]);
    label("E", [
      [3, 0],
      [3, 1],
    ]);
    label("SE", [
      [5, 1],
      [5, 2],
    ]);
    label("S", [
      [6, 3],
      [7, 2],
    ]);
    label("SW", [
      [5, 3],
      [6, 1],
    ]);
    label("W", [
      [4, 2],
      [4, 3],
    ]);
    label("NW", [
      [1, 0],
      [1, 1],
    ]);
    label("sleeping (antic)", [
      [2, 0],
      [2, 1],
    ]);
    label("tired (antic)", [[3, 2]]);
    label("scratchSelf (antic)", [
      [5, 0],
      [6, 0],
      [7, 0],
    ]);
    label("scratchWallN (antic)", [
      [0, 0],
      [0, 1],
    ]);
    label("scratchWallS (antic)", [
      [7, 1],
      [6, 2],
    ]);
    label("scratchWallE (antic)", [
      [2, 2],
      [2, 3],
    ]);
    label("scratchWallW (antic)", [
      [4, 0],
      [4, 1],
    ]);

    const grid = document.querySelector("#anatomy .grid");
    const readout = document.getElementById("anatomy-readout");
    if (grid && readout) {
      for (let row = 0; row < 4; row++) {
        for (let col = 0; col < 8; col++) {
          const cell = document.createElement("div");
          cell.className =
            "hover:outline hover:outline-2 hover:-outline-offset-2 hover:outline-ink hover:bg-amber/20";
          cell.addEventListener("mouseenter", () => {
            readout.textContent = `[${col}, ${row}] — ${STATES[`${col},${row}`] ?? "unmapped"}`;
          });
          grid.appendChild(cell);
        }
      }
      grid.addEventListener("mouseleave", () => {
        readout.textContent = "hover a cell";
      });
    }
  </script>
</Layout>
