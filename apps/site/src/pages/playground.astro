---
import Window from "../components/Window.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="onandemo.js — the playground"
  description="drop a recipe sheet and your pet is chasing your cursor instantly, then mint it into a link. nothing uploads — it all runs in your tab."
>
  <main class="mx-auto max-w-3xl space-y-10 px-4 py-10 sm:px-6">
    <!-- intro -->
    <Window title="the playground">
      <h1 class="text-4xl font-bold tracking-tight text-balance sm:text-5xl">
        drop a pet. it's loose.
      </h1>
      <p class="mt-4">
        drop a sheet from <a href="/recipe" class="prose-link">the recipe</a> and
        your companion chases your cursor — instantly, no slicing. then mint it into
        a link you can send anywhere. nothing uploads; it all runs in your tab.
      </p>
      <noscript>
        <p class="label mt-4">
          the playground runs in your tab — it needs javascript.
        </p>
      </noscript>
    </Window>

    <!-- the bench -->
    <Window title="your companion">
      <input
        id="pg-file"
        type="file"
        accept="image/png,image/gif,image/webp"
        class="hidden"
      />

      <!-- drop state -->
      <button
        id="pg-drop"
        type="button"
        class="border-ink hover:bg-ink/5 block w-full cursor-pointer border-2 border-dashed px-6 py-16 text-center"
      >
        <span class="label">drop your sheet here</span>
        <span class="mt-2 block text-sm">or click to pick a file</span>
        <span id="pg-drop-hint" class="label mt-4 block opacity-60">
          png / gif / webp · made with the recipe works best
        </span>
      </button>

      <!-- loaded state -->
      <div id="pg-stage" class="hidden">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <span class="label">
            <span class="text-amber-deep">●</span> it's chasing your cursor —
            <span id="pg-name" class="font-bold"></span>
            <span id="pg-dims" class="opacity-60"></span>
          </span>
          <button id="pg-swap" class="btn" type="button">swap</button>
        </div>

        <div class="mt-4 max-h-[60vh] overflow-auto pb-2">
          <div id="pg-frame" class="border-ink relative border-2 select-none">
            <img
              id="pg-img"
              alt="your dropped sheet, pixel-crisp"
              class="block"
              style="image-rendering: pixelated;"
              draggable="false"
            />
            <div id="pg-overlay" class="absolute top-0 left-0">
              <div id="pg-marks" class="pointer-events-none absolute inset-0">
              </div>
              <div
                id="pg-cursor"
                class="pointer-events-none absolute hidden"
                style="box-shadow: inset 0 0 0 2px rgb(0 0 0 / 0.5);"
              >
              </div>
            </div>
          </div>
        </div>
        <p class="label mt-2 h-5 opacity-60">
          cell: <span id="pg-readout">hover a cell</span>
        </p>

        <div class="mt-4 flex flex-wrap items-center gap-3">
          <span class="label">size</span>
          <div id="pg-scale" class="flex gap-1" role="group" aria-label="scale">
            <button class="btn" type="button" data-scale="1" aria-pressed="true"
              >1x</button
            >
            <button
              class="btn"
              type="button"
              data-scale="2"
              aria-pressed="false">2x</button
            >
            <button
              class="btn"
              type="button"
              data-scale="3"
              aria-pressed="false">3x</button
            >
            <button
              class="btn"
              type="button"
              data-scale="4"
              aria-pressed="false">4x</button
            >
          </div>
        </div>

        <!-- the mint -->
        <div class="border-ink/30 mt-6 border-t-2 pt-5">
          <div class="flex flex-wrap items-center gap-3">
            <button id="pg-mint" class="btn-amber" type="button"
              >mint a link</button
            >
            <span class="label opacity-60"
              >fold the whole pet into one link</span
            >
          </div>
          <div id="pg-mint-out" class="border-ink mt-4 hidden border-2 p-4">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <span class="label">your companion, link-shaped</span>
              <button id="pg-link-copy" class="btn" type="button"
                >copy link</button
              >
            </div>
            <p class="mt-3">
              <a
                id="pg-link"
                href=""
                class="prose-link font-mono text-sm break-all"></a>
            </p>
            <p class="label mt-3"><span id="pg-size"></span></p>
            <p id="pg-size-warn" class="mt-2 hidden text-sm">
              tiny sheets travel best — chat apps truncate long links.
            </p>
            <p class="mt-2 text-sm">
              nothing was uploaded — the creature lives in the link itself.
            </p>
          </div>
        </div>
      </div>
    </Window>

    <!-- advanced: the manual slicer, for non-recipe art -->
    <details id="pg-advanced" class="window">
      <summary
        class="window-title cursor-pointer list-none"
        style="justify-content: flex-start; padding-left: 16px;"
      >
        <span class="title-chip">different layout? slice it by hand</span>
      </summary>
      <div class="space-y-6 p-5">
        <p class="text-sm">
          dropped something that isn't a recipe sheet? set the cell size, pick a
          state, then click cells on the sheet above in the order they play.
          idle plus one direction is a legal pet (ADR-0007).
        </p>

        <div>
          <span class="label">cell size</span>
          <div class="mt-3 flex items-center gap-2">
            <label class="flex items-center gap-2 font-mono text-sm">
              w
              <input
                id="pg-cell-w"
                type="number"
                min="4"
                step="1"
                value="32"
                class="border-ink bg-paper w-20 border-2 px-2 py-1 font-mono text-sm"
              />
            </label>
            <span class="font-mono text-sm">×</span>
            <label class="flex items-center gap-2 font-mono text-sm">
              h
              <input
                id="pg-cell-h"
                type="number"
                min="4"
                step="1"
                value="32"
                class="border-ink bg-paper w-20 border-2 px-2 py-1 font-mono text-sm"
              />
            </label>
            <div id="pg-suggest" class="ml-2 flex flex-wrap gap-2">
              <button class="btn" type="button" data-cell="16">16</button>
              <button class="btn" type="button" data-cell="32">32</button>
              <button class="btn" type="button" data-cell="64">64</button>
              <button id="pg-auto" class="btn" type="button" disabled
                >guess</button
              >
            </div>
          </div>
        </div>

        <div>
          <span class="label">states</span>
          <div id="pg-states" class="mt-3 flex flex-wrap gap-2"></div>
          <div class="mt-4 flex gap-2">
            <input
              id="pg-antic-name"
              type="text"
              placeholder="antic name — sleep, spin, melt"
              class="border-ink bg-paper placeholder:text-ink/50 min-w-0 flex-1 border-2 px-2 py-1 font-mono text-sm"
            />
            <button id="pg-antic-add" class="btn shrink-0" type="button"
              >add antic</button
            >
          </div>
          <p id="pg-antic-err" class="label mt-2 h-4"></p>
        </div>

        <p id="pg-valid" class="label opacity-60">
          waiting on a sheet — idle plus one run direction makes a companion.
        </p>

        <div class="border-ink/30 border-t-2 pt-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <span class="text-sm"
              >or take the json for <code class="font-mono">data-frame-map</code
              ></span
            >
            <button id="pg-download" class="btn" type="button" disabled
              >download</button
            >
          </div>
          <p id="pg-serve" class="label mt-2 opacity-60">
            serve the json next to the image and point data-frame-map at it.
          </p>
        </div>
      </div>
    </details>
  </main>

  <script>
    import { initPlayground } from "../lib/playground.ts";
    initPlayground();
  </script>

  <style is:global>
    .btn:disabled,
    .btn-amber:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
    .btn:disabled:hover {
      background: var(--color-paper);
      color: var(--color-ink);
    }
    .btn-amber:disabled:hover {
      background: var(--color-amber);
      color: var(--color-ink);
    }
    .btn:disabled:active,
    .btn-amber:disabled:active {
      translate: none;
    }
    #pg-advanced summary::-webkit-details-marker {
      display: none;
    }
    #pg-advanced[open] summary {
      border-bottom: 2px solid var(--color-ink);
    }
  </style>
</Layout>
