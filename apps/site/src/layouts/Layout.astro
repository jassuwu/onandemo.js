---
import "@fontsource/dotgothic16";
import "@fontsource-variable/jetbrains-mono";
import "@fontsource/silkscreen";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "onandemo.js — oneko.js, but anything chases your cursor",
  description = "a cursor-companion engine: bundled pixel characters or your own sprite sheet, chasing the mouse with oneko's manners.",
} = Astro.props;

const path = Astro.url.pathname;
const nav = [
  { href: "/playground", label: "playground" },
  { href: "/recipe", label: "recipe" },
  { href: "https://github.com/jassuwu/onandemo.js", label: "github" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/og.png", Astro.site)} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />
  </head>
  <body class="desktop text-ink font-body min-h-dvh">
    <!-- the menu bar is the nav; the odometer sits where the clock goes -->
    <header
      class="bg-paper border-ink sticky top-0 z-40 border-b-2 px-3 sm:px-5"
    >
      <div class="mx-auto flex max-w-6xl items-stretch justify-between">
        <nav class="flex items-stretch">
          <a
            href="/"
            class="hover:bg-ink hover:text-paper flex items-center gap-2 px-3 py-2 font-bold"
          >
            <img
              src="/favicon.svg"
              alt=""
              width="16"
              height="16"
              class="inline-block"
              style="image-rendering: pixelated;"
            />
            onandemo.js
          </a>
          {
            nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "flex items-center px-3 py-2",
                  path.startsWith(item.href)
                    ? "bg-ink text-paper"
                    : "hover:bg-ink hover:text-paper",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <span class="label flex items-center gap-1.5">
          px chased: <span id="odometer" class="text-amber-deep">000000</span>
        </span>
      </div>
    </header>

    <slot />

    <footer class="mx-auto max-w-6xl px-4 pt-4 pb-10 sm:px-6">
      <div class="window inline-block px-4 py-2 text-sm">
        <a
          href="https://github.com/jassuwu/onandemo.js/blob/main/LICENSE"
          class="prose-link">MIT</a
        >
        ·
        <a
          href="https://github.com/jassuwu/onandemo.js/blob/main/packages/onandemo/NOTICE.md"
          class="prose-link">sprite receipts</a
        >
        · a love letter to
        <a href="https://github.com/adryd325/oneko.js" class="prose-link"
          >oneko.js</a
        >
      </div>
    </footer>

    <script>
      import { preview, summon, who } from "../lib/companion.ts";

      window.companion = { summon, preview, who };
      // /c owns its own mount (trailing slash included — hosts differ)
      if (!/^\/c\/?$/.test(location.pathname)) void summon("neko");

      // the one easter egg: how far has it run for you
      const odometer = document.getElementById("odometer");
      let last: [number, number] | null = null;
      let chased = 0;
      setInterval(() => {
        const el = document.getElementById("onandemo");
        if (!el) {
          last = null;
          return;
        }
        const x = parseFloat(el.style.left);
        const y = parseFloat(el.style.top);
        if (last) chased += Math.hypot(x - last[0], y - last[1]);
        last = [x, y];
        if (odometer) {
          odometer.textContent = String(Math.round(chased)).padStart(6, "0");
        }
      }, 400);

      // copy buttons, sitewide: any element with data-copy
      document.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLElement>(
          "[data-copy]",
        );
        if (!btn) return;
        const text = btn.dataset["copy"];
        if (!text) return;
        void navigator.clipboard.writeText(text).then(() => {
          const was = btn.textContent;
          btn.textContent = "copied";
          setTimeout(() => {
            btn.textContent = was;
          }, 900);
        });
      });
    </script>
  </body>
</html>
